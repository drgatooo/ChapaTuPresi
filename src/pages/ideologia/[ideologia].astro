---
export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/common/Heading.astro";
import Text from "@/components/common/Text.astro";
import { Icon } from "astro-icon/components";
import prisma from "@/lib/prisma";
import ideologiasData from "@/data/ideologias.json";
import { Cargo } from "@prisma/client";
import Partido from "@/components/landing/Partido.astro";

export async function getStaticPaths() {
  const uniqueIdeologies = Object.keys(ideologiasData) as (keyof typeof ideologiasData)[];

  return uniqueIdeologies.map(ide => ({
    params: { ideologia: ide.split(" ").join("_") },
    props: { 
      nombre: ide.split(" ").join("_"),
      definicion: ideologiasData[ide].resumen || "Definición en proceso de investigación por nuestro equipo editorial.",
      relacionados: ideologiasData[ide].relacionados || [],
      pilares: ideologiasData[ide].pilares || ["Justicia Social", "Libertad", "Progreso"] // Fallback
    }
  }));
}

const { nombre: nombreInit, definicion, relacionados, pilares } = Astro.props;

const nombre = nombreInit.split("_").join(" ");

// Traemos partidos y sus candidatos presidenciales para dar peso visual
const partidosRelacionados = await prisma.partido.findMany({
  where: { ideologia: { has: nombre } },
  include: {
    candidatos: {
      where: { cargo: { has: Cargo.PRESIDENTE } },
      take: 1
    }
  }
});

// Determinamos la posición predominante para la "Brújula"
const posicionMedia = partidosRelacionados[0]?.posicion || "Centro";
---

<Layout title={`¿Qué es el ${nombre}? - Chapa tu Presi`}>
  <header class="relative pt-32 pb-20 overflow-hidden bg-stone-50 dark:bg-stone-950">
    <span class="absolute -top-20 -right-20 text-[25rem] font-black text-stone-200/50 dark:text-stone-800/20 select-none pointer-events-none">
      {nombre.charAt(0)}
    </span>

    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="gap-16 items-center">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="h-1 w-12 bg-roof-terracotta-600"></div>
            <span class="text-xs font-black uppercase tracking-[0.3em] text-stone-500">Corriente ideológica</span>
          </div>
          <Heading level="h1" className="wrap-break-word text-4xl md:text-6xl lg:text-8xl font-black tracking-tighter mb-8">
            {nombre}<span class="text-roof-terracotta-600">.</span>
          </Heading>
          
          <div class="relative">
            <Icon name="mdi:format-quote-open" class="absolute -left-10 -top-6 text-stone-200 dark:text-stone-800 w-20 h-20 -z-10" />
            <Text class="text-lg md:text-xl leading-snug font-medium text-stone-700 dark:text-stone-300">
              {definicion}
            </Text>
          </div>
        </div>

        <!-- <div class="bg-white dark:bg-stone-900 p-8 rounded-3xl border border-stone-200 dark:border-stone-800 shadow-xl">
          <div class="flex justify-between items-end mb-8">
            <h4 class="text-sm font-black uppercase tracking-widest text-stone-400">Espectro Político</h4>
            <Pill className="bg-roof-terracotta-100 text-roof-terracotta-700 border-none">{posicionMedia}</Pill>
          </div>
          
          <div class="relative h-4 w-full bg-stone-100 dark:bg-stone-800 rounded-full flex items-center px-2">
            <div class="flex justify-between w-full text-[10px] font-bold text-stone-400 uppercase px-1 -top-6 absolute">
              <span>Izquierda</span>
              <span>Centro</span>
              <span>Derecha</span>
            </div>
            <div class={`h-6 w-6 bg-roof-terracotta-600 rounded-full shadow-lg border-4 border-white dark:border-stone-900 absolute transition-all duration-1000 
              ${posicionMedia.toLowerCase() === 'izquierda' ? 'left-0' : posicionMedia.toLowerCase() === 'derecha' ? 'left-[calc(100%-1.5rem)]' : 'left-[calc(50%-0.75rem)]'}`}>
            </div>
          </div>
          
        </div> -->
      </div>
    </div>
  </header>

  <section class="max-w-7xl mx-auto px-8 -mt-10 relative z-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {pilares.map((pilar) => (
        <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 p-6 rounded-2xl shadow-md flex flex-col items-center text-center gap-3">
          <Icon name="mdi:check-decagram" class="w-8 h-8 text-roof-terracotta-600" />
          <Text class="font-black text-sm uppercase tracking-tighter">{pilar}</Text>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-8 py-24">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="max-w-xl">
        <Heading level="h2" className="text-4xl mb-4">¿Quiénes lo proponen?</Heading>
        <Text>Estos son los partidos inscritos ante el JNE que basan su ideario en el {nombre}.</Text>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-5xl font-black text-stone-200 dark:text-stone-800">{partidosRelacionados.length}</span>
        <span class="text-xs font-bold uppercase text-stone-400">Organizaciones<br/>Encontradas</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {partidosRelacionados.map(partido => (
        <Partido partido={partido} />
      ))}
    </div>
  </section>

  {relacionados.length > 0 && (
    <section class="bg-stone-900 text-white py-20 overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-8 relative z-10">
        <h4 class="text-sm font-black uppercase tracking-[0.4em] text-stone-500 mb-10 text-center">Explora Ideas Similares</h4>
        <div class="flex flex-wrap justify-center gap-6">
          {relacionados.map(rel => (
            <a 
              href={`/ideologia/${rel.split(" ").join("_")}`} 
              class="group flex items-center gap-4 text-3xl md:text-5xl font-black text-stone-600 hover:text-white transition-all"
            >
              <span class="group-hover:text-roof-terracotta-600">#</span>
              {rel}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>