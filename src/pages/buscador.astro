---
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/common/Heading.astro";
import Text from "@/components/common/Text.astro";
import CustomSelect from "@/components/control/CustomSelect.astro";
import SegmentedControl from "@/components/control/SegmentedControl.astro"; // <-- Nuevo import
import { Icon } from "astro-icon/components";
import { Cargo } from "@prisma/client";

import prisma from "@/lib/prisma";

// Data Fetching
const regionesData = await prisma.candidato.findMany({ select: { postula_region: true }, distinct: ['postula_region'] });
const partidosData = await prisma.partido.findMany({ select: { id: true, slug: true, nombre: true, siglas: true, ideologia: true, posicion: true, logo_url: true } });

// Mapeos (Se mantiene igual...)
const optionsCargo = Object.values(Cargo).map(c => ({ value: c, label: c.replace(/_/g, ' ') }));
const optionsRegion = regionesData.filter(r => r.postula_region).map(r => ({ value: r.postula_region || "", label: r.postula_region || "Sin definir" }));
const optionsPartido = partidosData.sort((a, b) => a.siglas.localeCompare(b.siglas)).map(p => ({ value: p.slug, label: p.siglas, img: p.logo_url }));
const optionsIdeologia = [...new Set(partidosData.flatMap(p => p.ideologia))].sort().map(i => ({ value: i, label: i }));
const optionsPosicion = [...new Set(partidosData.map(p => p.posicion))].filter(Boolean).map(p => ({ value: p, label: p }));

// Opciones para el Segmented Control
const searchTypes = [
  { value: "candidatos", label: "Candidatos" },
  { value: "partidos", label: "Partidos" }
];
---

<Layout title="Buscador Avanzado Electoral - Chapa tu Presi">
  <main class="max-w-7xl mx-auto px-6 py-12">
    <header class="mb-12">
        <Heading level="h1" className="md:text-6xl mb-2 font-black">Buscador<span class="text-roof-terracotta-600">.</span></Heading>
        <p class="text-stone-500">Cruza datos, filtra antecedentes y encuentra al candidato ideal.</p>
    </header>

    <form id="search-form" class="grid lg:grid-cols-12 gap-8">
      <aside class="lg:col-span-4 xl:col-span-3 space-y-8 bg-stone-50 dark:bg-stone-900/50 p-6 rounded-3xl h-fit border border-stone-200 dark:border-stone-800">
        <div class="space-y-6">
          <div>
             <label class="text-[10px] font-black uppercase tracking-widest text-stone-400 block mb-3">Buscar Entidad:</label>
             <SegmentedControl name="type" options={searchTypes} defaultValue="candidatos" />
          </div>

          <div id="candidato-filters" class="space-y-5 pt-6 border-t border-stone-200 dark:border-stone-800 transition-opacity duration-300">
            <p class="text-xs font-black text-roof-terracotta-600 uppercase">Filtros de Candidato</p>
            <CustomSelect name="partido" label="Partido Político" options={optionsPartido} defaultText="Cualquier Partido" />
            <CustomSelect name="cargo" options={optionsCargo} defaultText="Cualquier Cargo" />
            <CustomSelect name="region" options={optionsRegion} defaultText="Cualquier Región" />
            <div class="space-y-3 pt-2">
               <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" name="sentencias" value="true" class="w-5 h-5 rounded text-roof-terracotta-600 focus:ring-roof-terracotta-500 bg-white dark:bg-stone-950 border-stone-300 dark:border-stone-700">
                  <Text tag="span" class="text-sm font-medium group-hover:text-roof-terracotta-600 transition-colors">Tiene Sentencias Penales</Text>
               </label>
               <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="checkbox" name="postgrado" value="true" class="w-5 h-5 rounded text-roof-terracotta-600 focus:ring-roof-terracotta-500 bg-white dark:bg-stone-950 border-stone-300 dark:border-stone-700">
                  <Text tag="span" class="text-sm font-medium group-hover:text-roof-terracotta-600 transition-colors">Tiene Postgrado / Maestría</Text>
               </label>
            </div>
          </div>

          <div id="partido-filters" class="hidden space-y-5 pt-6 border-t border-stone-200 dark:border-stone-800 transition-opacity duration-300">
            <p class="text-xs font-black text-roof-terracotta-600 uppercase">Filtros de Partido</p>
            
            <CustomSelect name="ideologia" options={optionsIdeologia} defaultText="Cualquier Ideología" />
            <CustomSelect name="posicion" options={optionsPosicion} defaultText="Cualquier Posición" />
            
            <label class="flex items-center gap-3 cursor-pointer mt-4">
                <input type="checkbox" name="alianza" value="true" class="w-5 h-5 rounded-full text-roof-terracotta-600 focus:ring-roof-terracotta-500">
                <Text tag="span" class="text-sm font-medium">Es Alianza Electoral</Text>
            </label>
          </div>
        </div>
      </aside>

      <div class="lg:col-span-8 xl:col-span-9 space-y-8">
        <div class="flex flex-col md:flex-row gap-4">
           <div class="relative grow">
              <input 
               type="text" 
               name="q"
               id="main-search-input"
               placeholder="Busca un candidato..." 
               class="dark:text-white w-full p-5 pl-14 bg-white dark:bg-stone-900 border-2 border-stone-200 dark:border-stone-800 rounded-2xl md:text-lg shadow-sm focus:border-roof-terracotta-500 outline-none transition-all"
              />
              <Icon name="mdi:magnify" class="absolute left-5 top-1/2 -translate-y-1/2 w-6 h-6 text-stone-400" />
           </div>
           
           <button type="submit" id="search-btn" class="bg-roof-terracotta-600 hover:bg-roof-terracotta-700 text-white font-black px-8 py-4 md:py-5 rounded-2xl transition-all flex justify-center items-center gap-2">
              BUSCAR
           </button>
        </div>

        <div id="results-container" class="space-y-10">
           <div class="py-32 text-center text-stone-400">
              <Icon name="mdi:filter-variant" class="w-16 h-16 mx-auto mb-4 opacity-50" />
              <p>Ajusta tus filtros y presiona Buscar o la tecla Enter.</p>
           </div>
        </div>
      </div>
    </form>
  </main>
</Layout>

<script>
  // Lógica de UI principal
  const form = document.getElementById('search-form') as HTMLFormElement;
  const resultsContainer = document.getElementById('results-container');
  const btn = document.getElementById('search-btn') as HTMLButtonElement;
  const mainInput = document.getElementById('main-search-input') as HTMLInputElement;

  const loadingSpinnerHtml = `<div class="grid w-full place-items-center overflow-x-scroll rounded-lg lg:overflow-visible">
  <svg class="text-transparent animate-spin" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg"
    width="24" height="24">
    <path
      d="M32 3C35.8083 3 39.5794 3.75011 43.0978 5.20749C46.6163 6.66488 49.8132 8.80101 52.5061 11.4939C55.199 14.1868 57.3351 17.3837 58.7925 20.9022C60.2499 24.4206 61 28.1917 61 32C61 35.8083 60.2499 39.5794 58.7925 43.0978C57.3351 46.6163 55.199 49.8132 52.5061 52.5061C49.8132 55.199 46.6163 57.3351 43.0978 58.7925C39.5794 60.2499 35.8083 61 32 61C28.1917 61 24.4206 60.2499 20.9022 58.7925C17.3837 57.3351 14.1868 55.199 11.4939 52.5061C8.801 49.8132 6.66487 46.6163 5.20749 43.0978C3.7501 39.5794 3 35.8083 3 32C3 28.1917 3.75011 24.4206 5.2075 20.9022C6.66489 17.3837 8.80101 14.1868 11.4939 11.4939C14.1868 8.80099 17.3838 6.66487 20.9022 5.20749C24.4206 3.7501 28.1917 3 32 3L32 3Z"
      stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"></path>
    <path
      d="M32 3C36.5778 3 41.0906 4.08374 45.1692 6.16256C49.2477 8.24138 52.7762 11.2562 55.466 14.9605C58.1558 18.6647 59.9304 22.9531 60.6448 27.4748C61.3591 31.9965 60.9928 36.6232 59.5759 40.9762"
      stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" class="text-white">
    </path>
  </svg>
</div>`;

  // Lógica para alternar filtros según el SegmentedControl
  document.getElementById('segment-type')?.addEventListener('change', (e) => {
    const val = (e.target as HTMLInputElement).value;
    const candFilters = document.getElementById('candidato-filters');
    const partFilters = document.getElementById('partido-filters');
    
    if (val === 'candidatos') {
      candFilters?.classList.remove('hidden');
      partFilters?.classList.add('hidden');
      mainInput.placeholder = "Busca un candidato (ej. Rafael Lopez)...";
    } else if (val === 'partidos') {
      candFilters?.classList.add('hidden');
      partFilters?.classList.remove('hidden');
      mainInput.placeholder = "Busca un partido (ej. APRA, Fuerza Popular)...";
    }
  });

  // Envío del Formulario
  form?.addEventListener('submit', async (e) => {
    e.preventDefault(); 
    
    if (resultsContainer) {
      resultsContainer.innerHTML = '<div class="text-center py-20"><span class="animate-pulse text-stone-400">Buscando en la base de datos...</span></div>';
    }
    
    const originalBtnText = btn.innerHTML;
    btn.innerHTML = loadingSpinnerHtml;
    btn.disabled = true;

    // FormData captura automáticamente los valores de los inputs ocultos de los CustomSelects
    const formData = new FormData(form);
    const params = new URLSearchParams();
    
    for (const [key, value] of formData.entries()) {
      if (value) params.append(key, value.toString());
    }

    try {
      const res = await fetch(`/api/search?${params.toString()}`);
      const data = await res.json();
      renderResults(data);
    } catch (error) {
      if (resultsContainer) resultsContainer.innerHTML = '<p class="text-center text-red-500">Hubo un error al buscar.</p>';
    } finally {
      btn.innerHTML = originalBtnText;
      btn.disabled = false;
    }
  });

  // Mapa de jerarquía de cargos
  const cargoWeight: Record<string, number> = {
    "PRESIDENTE": 1, "PRIMER_VICEPRESIDENTE": 2, "SEGUNDO_VICEPRESIDENTE": 3,
    "SENADOR": 4, "DIPUTADO": 5, "PARLAMENTO_ANDINO": 6
  };

  function renderResults(data: any) {
    if (!resultsContainer) return;
    
    if (data.partidos.length === 0 && data.candidatos.length === 0) {
      resultsContainer.innerHTML = `
        <div class="py-20 text-center flex flex-col items-center gap-4">
          <div class="p-4 bg-stone-100 dark:bg-stone-800 rounded-full text-stone-400">
             <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
          </div>
          <p class="text-stone-500 font-medium">No se encontraron resultados exactos.</p>
          <p class="text-xs text-stone-400">Prueba quitando algunos filtros o buscando un término más general.</p>
        </div>
      `;
      return;
    }

    let html = '';

    // SECCIÓN PARTIDOS
    if (data.partidos.length > 0) {
      html += `
        <div>
          <h3 class="text-xl font-black mb-4 dark:text-white flex items-center gap-2">
             <svg class="w-6 h-6 text-roof-terracotta-600" viewBox="0 0 24 24" fill="currentColor"><path d="M14 16.5V22h-4v-5.5l-4-4V3h12v9.5l-4 4z"/></svg> 
             Partidos Encontrados <span class="text-sm font-bold text-stone-400 bg-stone-100 dark:bg-stone-800 px-2 py-0.5 rounded-md ml-2">${data.partidos.length}</span>
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      `;
      data.partidos.forEach((p: any) => {
        html += `
          <a href="/partido/${p.slug}" class="p-5 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl flex items-center gap-4 hover:border-roof-terracotta-500 transition-all group shadow-sm hover:shadow-md">
            <img src="${p.logo_url}" class="w-12 h-12 object-contain" />
            <div class="overflow-hidden">
              <h4 class="dark:text-white font-black text-sm uppercase group-hover:text-roof-terracotta-600 transition-colors truncate">${p.nombre}</h4>
              <span class="text-[10px] text-stone-400 font-bold tracking-widest">${p.siglas}</span>
            </div>
          </a>
        `;
      });
      html += `</div></div>`;
    }

    // SECCIÓN CANDIDATOS
    if (data.candidatos.length > 0) {
      const sortedCandidatos = data.candidatos;

      html += `
        <div>
          <h3 class="text-xl font-black mb-4 dark:text-white flex items-center gap-2">
             <svg class="w-6 h-6 text-roof-terracotta-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
             Candidatos Encontrados <span class="text-sm font-bold text-stone-400 bg-stone-100 dark:bg-stone-800 px-2 py-0.5 rounded-md ml-2">${data.candidatos.length}</span>
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      `;
      sortedCandidatos.forEach((c: any) => {
        const hasSentencias = c.sentencias.length > 0;
        html += `
          <a href="/candidato/${c.slug}" class="p-4 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl flex items-center gap-4 hover:border-roof-terracotta-500 transition-all group shadow-sm hover:shadow-md">
            <div class="relative w-14 h-14 shrink-0">
              <img src="${c.foto_url}" class="w-full h-full rounded-xl object-cover" />
              ${hasSentencias ? '<span class="absolute -top-1 -right-1 w-4 h-4 bg-red-600 rounded-full border-2 border-white dark:border-stone-900" title="Sentencias Registradas"></span>' : ''}
            </div>
            <div class="flex-grow overflow-hidden">
              <h4 class="dark:text-white font-bold text-sm truncate group-hover:text-roof-terracotta-600 transition-colors leading-tight">${c.nombre} ${c.apellido_p}</h4>
              <p class="text-[10px] font-black text-stone-400 uppercase tracking-tighter truncate mt-1 flex items-center gap-1">
                 <img src="${c.partido.logo_url}" class="w-3 h-3 inline object-contain grayscale" /> 
                 ${c.partido.siglas}
              </p>
              <span class="inline-block mt-1 bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-300 text-[9px] px-2 py-0.5 rounded uppercase font-bold tracking-widest">
                 ${c.cargo[0].replace(/_/g, ' ')}
              </span>
            </div>
          </a>
        `;
      });
      html += `</div></div>`;
    }

    resultsContainer.innerHTML = html;
  }
</script>