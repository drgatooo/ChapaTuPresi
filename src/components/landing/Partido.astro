---
import { Icon } from "astro-icon/components";
import Pill from "../common/Pill.astro";

interface PartialPartido {
  slug: string;
  nombre: string;
  siglas: string;
  logo_url: string;
  ideologia: string[];
  posicion: string;
  color: string;
  candidatos: {
    nombre: string;
    apellido_p: string;
    apellido_m: string;
    foto_url: string;
  }[];
}

interface Props {
  partido: PartialPartido;
}

const { partido } = Astro.props;
---

<a
  href={`/partido/${partido.slug}`}
  class="party-card group relative bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-2xl overflow-hidden transition-all hover:border-roof-terracotta-500/50 hover:shadow-2xl hover:shadow-roof-terracotta-500/10 hover:-translate-y-2"
  data-name={partido.nombre.toLowerCase()}
  data-siglas={partido.siglas.toLowerCase()}
  data-posicion={partido.posicion.toLowerCase()}
  data-candidate={partido.candidatos[0]
    ? `${partido.candidatos[0].nombre} ${partido.candidatos[0].apellido_p} ${partido.candidatos[0].apellido_m}`.toLowerCase()
    : ""}
>
  <div
    class="absolute left-0 top-0 bottom-0 w-1.5"
    style={`background-color: ${partido.color}`}
  >
  </div>

  <div class="p-6 h-full flex flex-col">
    <div class="flex justify-between items-start mb-6">
      <div
        class="w-20 h-20 bg-stone-50 dark:bg-stone-100 rounded-2xl p-3 border border-stone-100 dark:border-stone-700 shrink-0 shadow-inner"
      >
        <img
          src={partido.logo_url}
          alt={partido.siglas}
          class="w-full h-full object-contain lg:grayscale-75 group-hover:grayscale-0 transition-all duration-200"
        />
      </div>
      <div class="text-right">
        <span
          class="text-xs font-black text-stone-300 dark:text-stone-700 tracking-tighter group-hover:text-roof-terracotta-200 transition-colors"
        >
          #{partido.siglas}
        </span>
      </div>
    </div>

    <div class="space-y-4 flex flex-col justify-between grow">
      <div>
        <h3
          class="font-black text-xl leading-tight text-stone-900 dark:text-white group-hover:text-roof-terracotta-600 transition-colors line-clamp-2"
        >
          {partido.nombre}
        </h3>
        <div class="flex items-center gap-2 mt-2">
          <span
            class={`w-2 h-2 rounded-full`}
            style={`background-color: ${partido.color}`}></span>
          <span
            class="text-[10px] font-bold uppercase tracking-widest text-stone-400"
          >
            {partido.posicion}
          </span>
        </div>
        {
          partido.ideologia.length > 0 && (
            <div class="flex items-center gap-2 mt-4">
              <Pill
                className="text-xs font-bold uppercase tracking-widest bg-stone-100 dark:bg-stone-700"
                spanClassName="text-stone-400 text-[10px]"
              >
                {partido.ideologia[0]}
              </Pill>
              {partido.ideologia.length > 1 && (
                <Pill
                  className="text-xs font-bold uppercase tracking-widest bg-stone-100 dark:bg-stone-700"
                  spanClassName="text-stone-400 text-[10px]"
                >
                  +{partido.ideologia.length - 1}
                </Pill>
              )}
            </div>
          )
        }
      </div>

      <div
        class="pt-4 border-t border-stone-100 dark:border-stone-800 flex items-center gap-3"
      >
        <div
          class="w-8 h-8 rounded-full bg-stone-200 dark:bg-stone-700 flex items-center justify-center"
        >
          {
            partido.candidatos[0] ? (
              <img
                src={partido.candidatos[0].foto_url}
                alt={`${partido.candidatos[0].nombre} ${partido.candidatos[0].apellido_p}`}
                class="w-full h-full object-cover rounded-full president-candidate-photo"
              />
            ) : (
              <Icon name="mdi:account" class="text-stone-400 w-5 h-5" />
            )
          }
        </div>
        <div class="flex flex-col">
          <span class="text-[9px] uppercase font-bold text-stone-400">
            Presidenciable
          </span>
          <span class="text-sm font-bold text-stone-700 dark:text-stone-300">
            {
              partido.candidatos[0]
                ? `${partido.candidatos[0].nombre} ${partido.candidatos[0].apellido_p}`
                : "No definido"
            }
          </span>
        </div>
      </div>
    </div>
  </div>
</a>
